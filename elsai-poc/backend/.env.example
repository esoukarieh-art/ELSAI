# Clé API Anthropic (obligatoire)
ANTHROPIC_API_KEY=sk-ant-xxxxx

# Modèle Claude
CLAUDE_MODEL=claude-sonnet-4-6

# Base de données (SQLite par défaut pour le POC)
DATABASE_URL=sqlite:///./elsai_poc.db

# Secret pour les JWT sessions anonymes
JWT_SECRET=change-me-in-production-please-use-openssl-rand-hex-32
JWT_ALGORITHM=HS256
SESSION_EXPIRE_MINUTES=60

# CORS - origines autorisées (frontend Next.js)
CORS_ORIGINS=http://localhost:3000

# Tesseract (Windows: chemin vers tesseract.exe si pas dans PATH)
TESSERACT_CMD=

# Token admin pour /api/dashboard/metrics (vide = dashboard désactivé)
# Générer avec : openssl rand -hex 32
ADMIN_TOKEN=

# === Stripe (facturation B2B) ===
# Clé secrète Stripe (sk_test_... en dev, sk_live_... en prod)
STRIPE_SECRET_KEY=
# Secret du webhook (whsec_...) fourni par `stripe listen` ou dashboard Stripe
STRIPE_WEBHOOK_SECRET=
# Price IDs (price_...) créés dans le dashboard Stripe — un par plan/cadence
STRIPE_PRICE_ESSENTIEL_MONTHLY=
STRIPE_PRICE_ESSENTIEL_YEARLY=
STRIPE_PRICE_PREMIUM_MONTHLY=
STRIPE_PRICE_PREMIUM_YEARLY=
# URLs de retour après checkout / portail
BILLING_SUCCESS_URL=http://localhost:3000/offre/merci
BILLING_CANCEL_URL=http://localhost:3000/offre
BILLING_PORTAL_RETURN_URL=http://localhost:3000/offre

# === Brevo (email transactionnel) ===
# Clé API v3 Brevo (https://app.brevo.com/settings/keys/api)
BREVO_API_KEY=
BREVO_SENDER_EMAIL=no-reply@elsai.fr
BREVO_SENDER_NAME=ELSAI
# URL publique du frontend (pour les liens dans les emails)
FRONTEND_BASE_URL=http://localhost:3000

# RGPD — durée (heures) avant purge auto d'une session inactive
SESSION_RETENTION_HOURS=24

# Observabilité
# Niveau de log : DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO
# Sentry DSN (vide = désactivé). Préférer self-host ou Sentry.io EU pour RGPD.
SENTRY_DSN=
SENTRY_ENVIRONMENT=dev
SENTRY_RELEASE=
SENTRY_TRACES_SAMPLE_RATE=0.1
